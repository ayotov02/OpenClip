# ============================================================================
# OpenClip — Premium Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# This backend uses cloud APIs instead of local GPU models.
# Runs on any $5/month VPS — no GPU required.
# Requires API keys for: Clerk, OpenRouter, Kie.ai, Bright Data.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
# Do not change APP_MODE — this must be "premium" for the premium backend.
APP_MODE=premium
APP_VERSION=0.1.0
DEBUG=false

# Domain (used for Caddy TLS and CORS in Docker)
DOMAIN=openclip.local

# Comma-separated list of allowed CORS origins (your frontend URL).
# For Docker Compose: includes both local dev and domain.
# For production: ["https://your-domain.com"]
CORS_ORIGINS=["https://openclip.local","http://localhost:3000"]

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Docker Compose: use the service name "postgres" as HOST.
DATABASE_URL=

# ── Redis ──────────────────────────────────────────────────────────────────
# Used for: Celery task broker, WebSocket pub/sub, rate limiting.
# Docker Compose: use the service name "redis" as HOST.
REDIS_URL=

# ── Object Storage (MinIO / S3) ────────────────────────────────────────────
# S3-compatible storage for videos, images, audio, and generated assets.
# Docker Compose: use the service name "minio" as the endpoint.
# For AWS S3: set MINIO_ENDPOINT=s3.amazonaws.com and MINIO_SECURE=true
# For GCS: use interoperability mode with HMAC keys.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=openclip
MINIO_SECURE=false

# ── Auth (Clerk) ───────────────────────────────────────────────────────────
# Managed authentication with OAuth (Google, GitHub, etc.).
# Create a Clerk app at: https://dashboard.clerk.com
# REQUIRED — the app will not start without valid Clerk keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ── LLM (OpenRouter) ──────────────────────────────────────────────────────
# Unified LLM API with automatic model fallback.
# Sign up at: https://openrouter.ai
# REQUIRED — powers clip scoring, script generation, B-roll queries.
OPENROUTER_API_KEY=

# Primary model. Recommended: anthropic/claude-sonnet-4-5-20250929
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-5-20250929

# Fallback model chain (JSON array).
OPENROUTER_FALLBACK_MODELS=["openai/gpt-5","google/gemini-3-pro"]

# ── Media Generation (Kie.ai) ─────────────────────────────────────────────
# Sign up at: https://kie.ai
# REQUIRED — powers all media generation (images, video, voice, music).
KIEAI_API_KEY=

# Webhook URL for async task completion notifications.
# For local dev, use a tunnel: ngrok http 8000
KIEAI_WEBHOOK_URL=

# Default models per media type.
KIEAI_DEFAULT_IMAGE_MODEL=gpt-image/1-5-text-to-image
KIEAI_DEFAULT_VIDEO_MODEL=runway-api/generate-ai-video
KIEAI_DEFAULT_TTS_MODEL=elevenlabs/text-to-speech-turbo-2-5
KIEAI_DEFAULT_MUSIC_MODEL=suno-api/generate-music

# ── Web Scraping (Bright Data) ────────────────────────────────────────────
# Sign up at: https://brightdata.com
# OPTIONAL — competitor tracking won't work without it.
BRIGHTDATA_API_KEY=

# Zone names from your Bright Data dashboard.
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_BROWSER_ZONE=
BRIGHTDATA_UNLOCKER_ZONE=

# ── B-Roll Stock Footage (Pexels) ─────────────────────────────────────────
# Get your free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Docker Compose Credentials ──────────────────────────────────────────
# Used by docker-compose.yml for service configuration.
POSTGRES_PASSWORD=
REDIS_PASSWORD=
