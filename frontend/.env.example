# ============================================================================
# OpenClip — Frontend Environment Variables
# ============================================================================
# Copy this file to .env.local and adjust as needed.
#   cp .env.example .env.local
# ============================================================================

# Backend API URL used by Next.js rewrites to proxy /api/v1/* requests.
# For standalone dev: http://127.0.0.1:8000
# In Docker: not needed — Caddy handles same-origin routing.
NEXT_PUBLIC_API_URL=
