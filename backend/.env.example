# ============================================================================
# OpenClip — Local Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# This backend runs ALL AI models locally on your machine (GPU required).
# No paid API calls. No usage credits. No data leaves your machine.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
# Do not change APP_MODE — this must be "local" for the local backend.
APP_MODE=local
APP_VERSION=0.1.0
DEBUG=false

# Domain (used for Caddy TLS and CORS in Docker)
DOMAIN=openclip.local

# Comma-separated list of allowed CORS origins (your frontend URL).
# For Docker Compose: includes both local dev and domain.
# For production: ["https://your-domain.com"]
CORS_ORIGINS=["https://openclip.local","http://localhost:3000"]

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Docker Compose: use the service name "postgres" as HOST.
DATABASE_URL=

# ── Redis ──────────────────────────────────────────────────────────────────
# Used for: Celery task broker, WebSocket pub/sub, rate limiting.
# Docker Compose: use the service name "redis" as HOST.
REDIS_URL=

# ── Object Storage (MinIO / S3) ────────────────────────────────────────────
# S3-compatible storage for videos, images, audio, and generated assets.
# Docker Compose: use the service name "minio" as the endpoint.
# For AWS S3: set MINIO_ENDPOINT=s3.amazonaws.com and MINIO_SECURE=true
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=openclip
MINIO_SECURE=false

# ── Auth (Self-Managed JWT) ────────────────────────────────────────────────
# The local backend handles its own authentication via JWT tokens.
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── LLM (Ollama) ──────────────────────────────────────────────────────────
# Ollama serves the local language model for clip scoring, script generation,
# B-roll queries, and publish copy generation.
# Docker Compose: use the service name "ollama" as HOST.
# Models: qwen3:32b (recommended), qwen3:14b (lighter), llama3.1:70b
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3:32b

# ── Speech-to-Text (WhisperX) ─────────────────────────────────────────────
WHISPER_SERVICE_URL=

# ── Text-to-Speech (Kokoro / Chatterbox) ──────────────────────────────────
TTS_SERVICE_URL=

# ── Computer Vision (YOLO11 + MediaPipe) ──────────────────────────────────
CV_SERVICE_URL=

# ── Image Generation (FLUX.1 schnell) ─────────────────────────────────────
FLUX_SERVICE_URL=

# ── Music Generation (Meta MusicGen) ──────────────────────────────────────
MUSICGEN_SERVICE_URL=

# ── B-Roll Stock Footage (Pexels) ─────────────────────────────────────────
# Get your free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Docker Compose Credentials ──────────────────────────────────────────
# Used by docker-compose.yml for service configuration.
POSTGRES_PASSWORD=
REDIS_PASSWORD=
